# Backend environment configuration. Copy to .env and edit for local dev.

# Comma-separated list of allowed CORS origins.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Optional: path to a directory of real PJM CSVs. If unset, synthetic data is used.
# PJM_DATA_DIR=/data/pjm

# Uvicorn / Railway will set PORT automatically.
# PORT=8000
